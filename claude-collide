#!/usr/bin/env python3
"""
claude-collide — submit commands to the tt-device-queue server.

Usage:
  claude-collide queue <command...>                Submit a job, return immediately
  claude-collide job <job_id>                      Show structured job status
  claude-collide logs <job_id> [offset] [limit]   Read current job logs
  claude-collide power                             Sample board power directly
  claude-collide result <job_id>                   Check if a job is done
  claude-collide exec <command...>                 Submit + block until done
  claude-collide kill                              Kill the running job
  claude-collide status                            Show queue status
  claude-collide reset                             Queue a device reset (tt-smi -r)

Options (before subcommand):
  --timeout N     Execution timeout in seconds (default: 120)
  --repeat N      Run the command N times sequentially (default: 1)
  --port PORT     Server port (default: 5741)
  --cwd DIR       Working directory for the command (default: current directory)

Examples:
  claude-collide --cwd ~/tenstorrent/blackhole-py queue PYTHONPATH=. uv run examples/matmul_peak.py
  claude-collide result a1b2c3d4
  claude-collide --cwd ~/tenstorrent/blackhole-py exec PYTHONPATH=. uv run examples/matmul_peak.py
  claude-collide status
"""

import json
import os
import sys
import time
from pathlib import Path

from queue_client import QueueClientError, get, post, run_power_watch

HOST = "127.0.0.1"
PORT = int(os.environ.get("TT_DEVICE_PORT", "5741"))
DEFAULT_TIMEOUT = 120
BASE = f"http://{HOST}:{PORT}"
REPO_ROOT = Path(__file__).resolve().parent
POWER_WATCH = REPO_ROOT / "power_watch.py"

def http_post(path, data):
  try:
    return post(BASE, path, data)
  except QueueClientError as exc:
    print(f"ERROR: {exc}", file=sys.stderr)
    sys.exit(1)


def http_get(path):
  try:
    return get(BASE, path)
  except QueueClientError as exc:
    print(f"ERROR: {exc}", file=sys.stderr)
    sys.exit(1)


def cmd_queue(cmd: str, timeout: int, cwd: str, repeat: int):
  if repeat < 1:
    print("ERROR: --repeat must be >= 1", file=sys.stderr)
    sys.exit(1)
  data = http_post("/queue", {
    "cmd": cmd, "cwd": cwd, "timeout": timeout, "repeat": repeat,
  })

  print(f"job_id={data['job_id']}")
  print(f"output_file={data['output_file']}")
  print(f"position={data['position']}")
  print(f"estimated_wait_sec={data['estimated_wait_sec']}")
  if "estimated_run_sec" in data:
    print(f"estimated_run_sec={data['estimated_run_sec']}")
  print(f"repeat={repeat}")


def cmd_result(job_id: str):
  data = http_get(f"/result/{job_id}")
  if data["status"] == "done":
    print(f"status=done")
    print(f"exit_code={data['exit_code']}")
    print(f"output_file={data['output_file']}")
    print(f"elapsed={data['elapsed']}")
  else:
    print(f"status={data['status']}")
    print(f"position={data.get('position', '?')}")
    print(f"estimated_wait_sec={data.get('estimated_wait_sec', '?')}")


def cmd_job(job_id: str):
  data = http_get(f"/job/{job_id}")
  print(json.dumps(data, indent=2))


def cmd_logs(job_id: str, offset: int = 0, limit: int = 16384):
  data = http_get(f"/logs/{job_id}?offset={offset}&limit={limit}")
  sys.stdout.write(data.get("content", ""))
  if data.get("truncated"):
    print(f"\n[claude-collide] More logs available; next_offset={data.get('next_offset')}", file=sys.stderr)


def cmd_power():
  try:
    print(run_power_watch(REPO_ROOT, POWER_WATCH))
  except QueueClientError as exc:
    print(f"ERROR: {exc}", file=sys.stderr)
    sys.exit(1)


def cmd_exec(cmd: str, timeout: int, cwd: str, repeat: int):
  """Submit, poll until done, print result."""
  if repeat < 1:
    print("ERROR: --repeat must be >= 1", file=sys.stderr)
    sys.exit(1)
  data = http_post("/queue", {
    "cmd": cmd, "cwd": cwd, "timeout": timeout, "repeat": repeat,
  })

  job_id = data["job_id"]
  output_file = data["output_file"]
  wait = data["estimated_wait_sec"]

  if wait > 0:
    print(f"[claude-collide] Queued (position {data['position']}, ~{wait}s wait)", file=sys.stderr)

  # Poll until done
  while True:
    if wait > 0:
      time.sleep(min(wait, 5))
    else:
      time.sleep(2)

    result = http_get(f"/result/{job_id}")

    if result["status"] == "done":
      print(f"exit_code={result['exit_code']}")
      print(f"output_file={result['output_file']}")
      print(f"elapsed={result['elapsed']}")

      # Print a short tail of the output for immediate feedback
      try:
        with open(output_file, "r") as f:
          lines = f.readlines()
          tail = lines[-20:] if len(lines) > 20 else lines
          if len(lines) > 20:
            print(f"... ({len(lines) - 20} lines truncated, see {output_file})", file=sys.stderr)
          for line in tail:
            sys.stdout.write(line)
      except FileNotFoundError:
        pass

      sys.exit(0 if result["exit_code"] == 0 else 1)
    else:
      wait = result.get("estimated_wait_sec", 5)
      print(f"[claude-collide] Still {result['status']} (position {result.get('position', '?')}, ~{wait}s)", file=sys.stderr)


def cmd_status():
  data = http_get("/status")
  current = data.get("current")
  pending = data.get("pending", [])
  recent = data.get("recent", [])

  if current:
    print(f"RUNNING: [{current['id']}] {current['cmd']}")
    repeat = current.get("repeat", 1)
    progress = f"  repeat {current.get('repeat_current', 0)}/{repeat}" if repeat > 1 else ""
    eta = current.get("estimated_remaining_sec")
    eta_text = f"  eta ~{eta}s" if eta is not None else ""
    print(f"         {current['running_sec']}s{progress}{eta_text}")
  else:
    print("RUNNING: (idle)")

  if pending:
    print(f"\nQUEUED ({len(pending)}):")
    for p in pending:
      print(f"  [{p['id']}] {p['cmd']}")
      repeat = f"  repeat {p['repeat']}x" if p.get('repeat', 1) > 1 else ""
      eta = p.get("estimated_wait_sec")
      eta_text = f"  eta ~{eta}s" if eta is not None else ""
      print(f"           waiting {p['waiting_sec']}s{repeat}{eta_text}")
  else:
    print("\nQUEUED: (empty)")

  if recent:
    print(f"\nRECENT:")
    for r in recent:
      tag = "OK" if r.get("exit_code", 1) == 0 else f"FAIL({r.get('exit_code')})"
      repeat = r.get("repeat", 1)
      suffix = f"  repeat {r.get('repeat_completed', 0)}/{repeat}" if repeat > 1 else ""
      print(f"  [{r['id']}] {tag} {r.get('elapsed', '?')}s  {r['cmd']}{suffix}")


def cmd_kill():
  data = http_post("/kill", {})
  killed = data.get("killed")
  if killed:
    print(f"killed=[{killed['id']}] {killed['cmd']}")
  else:
    print("nothing_running=true")


def cmd_reset():
  data = http_post("/queue", {
    "cmd": "tt-smi -r", "cwd": "", "timeout": 30,
  })
  print(f"job_id={data['job_id']}")
  print(f"position={data['position']}")
  print(f"estimated_wait_sec={data['estimated_wait_sec']}")


def main():
  argv = sys.argv[1:]
  timeout = DEFAULT_TIMEOUT
  repeat = 1

  cwd = None

  # Parse global options
  while argv and (argv[0].startswith("--") or argv[0] in ("-h",)):
    if argv[0] == "--timeout" and len(argv) > 1:
      timeout = int(argv[1])
      argv = argv[2:]
    elif argv[0] == "--repeat" and len(argv) > 1:
      repeat = int(argv[1])
      argv = argv[2:]
    elif argv[0] == "--port" and len(argv) > 1:
      global PORT, BASE
      PORT = int(argv[1])
      BASE = f"http://{HOST}:{PORT}"
      argv = argv[2:]
    elif argv[0] == "--cwd" and len(argv) > 1:
      cwd = os.path.expanduser(argv[1])
      argv = argv[2:]
    elif argv[0] in ("--help", "-h"):
      print(__doc__.strip())
      sys.exit(0)
    else:
      break

  if not argv:
    print(__doc__.strip())
    sys.exit(1)

  subcmd = argv[0]
  rest = argv[1:]

  effective_cwd = cwd or os.getcwd()

  if subcmd == "queue":
    if not rest:
      print("Usage: claude-collide queue <command...>", file=sys.stderr)
      sys.exit(1)
    cmd_queue(" ".join(rest), timeout, effective_cwd, repeat)

  elif subcmd == "result":
    if not rest:
      print("Usage: claude-collide result <job_id>", file=sys.stderr)
      sys.exit(1)
    cmd_result(rest[0])

  elif subcmd == "job":
    if not rest:
      print("Usage: claude-collide job <job_id>", file=sys.stderr)
      sys.exit(1)
    cmd_job(rest[0])

  elif subcmd == "logs":
    if not rest:
      print("Usage: claude-collide logs <job_id> [offset] [limit]", file=sys.stderr)
      sys.exit(1)
    offset = int(rest[1]) if len(rest) > 1 else 0
    limit = int(rest[2]) if len(rest) > 2 else 16384
    cmd_logs(rest[0], offset, limit)

  elif subcmd == "power":
    cmd_power()

  elif subcmd == "exec":
    if not rest:
      print("Usage: claude-collide exec <command...>", file=sys.stderr)
      sys.exit(1)
    cmd_exec(" ".join(rest), timeout, effective_cwd, repeat)

  elif subcmd == "status":
    cmd_status()

  elif subcmd == "kill":
    cmd_kill()

  elif subcmd == "reset":
    cmd_reset()

  else:
    print(f"Unknown subcommand: {subcmd}", file=sys.stderr)
    print(__doc__.strip())
    sys.exit(1)


if __name__ == "__main__":
  main()
